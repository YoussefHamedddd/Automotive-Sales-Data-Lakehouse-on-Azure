    "%sql\n",
    "-- ============================================================\n",
    "-- ANALYTICS VIEWS — Gold Layer\n",
    "-- ============================================================\n",
    "\n",
    "USE cars_catalog.gold;\n",
    "\n",
    "-- ------------------------------------------------------------\n",
    "-- VIEW 1: Revenue by Branch per Quarter\n",
    "-- ------------------------------------------------------------\n",
    "CREATE OR REPLACE VIEW vw_revenue_by_branch AS\n",
    "SELECT\n",
    "    f.Branch_ID,\n",
    "    b.BranchName,\n",
    "    d.Year,\n",
    "    d.Quarter,\n",
    "    ROUND(SUM(f.Revenue),    2) AS Total_Revenue,\n",
    "    SUM(f.Units_Sold)           AS Total_Units,\n",
    "    ROUND(AVG(f.Revenue),    2) AS Avg_Revenue,\n",
    "    COUNT(*)                    AS Num_Transactions\n",
    "FROM fact_sales      f\n",
    "JOIN dim_branch      b ON f.Branch_ID = b.Branch_ID\n",
    "JOIN dim_date        d ON f.Date_ID   = d.Date_ID\n",
    "GROUP BY f.Branch_ID, b.BranchName, d.Year, d.Quarter\n",
    "ORDER BY d.Year, d.Quarter, Total_Revenue DESC;\n",
    "\n",
    "-- ------------------------------------------------------------\n",
    "-- VIEW 2: Revenue by Product per Year\n",
    "-- ------------------------------------------------------------\n",
    "CREATE OR REPLACE VIEW vw_revenue_by_product AS\n",
    "SELECT\n",
    "    f.Model_ID,\n",
    "    p.Product_Name,\n",
    "    p.Brand,\n",
    "    d.Year,\n",
    "    ROUND(SUM(f.Revenue),    2) AS Total_Revenue,\n",
    "    SUM(f.Units_Sold)           AS Total_Units,\n",
    "    ROUND(AVG(f.Revenue),    2) AS Avg_Revenue\n",
    "FROM fact_sales      f\n",
    "JOIN dim_product     p ON f.Model_ID  = p.Model_ID\n",
    "JOIN dim_date        d ON f.Date_ID   = d.Date_ID\n",
    "GROUP BY f.Model_ID, p.Product_Name, p.Brand, d.Year\n",
    "ORDER BY d.Year, Total_Revenue DESC;\n",
    "\n",
    "-- ------------------------------------------------------------\n",
    "-- VIEW 3: Revenue by Dealer per Quarter\n",
    "-- ------------------------------------------------------------\n",
    "CREATE OR REPLACE VIEW vw_revenue_by_dealer AS\n",
    "SELECT\n",
    "    f.Dealer_ID,\n",
    "    dl.DealerName,\n",
    "    d.Year,\n",
    "    d.Quarter,\n",
    "    ROUND(SUM(f.Revenue),    2) AS Total_Revenue,\n",
    "    SUM(f.Units_Sold)           AS Total_Units,\n",
    "    ROUND(AVG(f.Revenue),    2) AS Avg_Revenue\n",
    "FROM fact_sales      f\n",
    "JOIN dim_dealer      dl ON f.Dealer_ID = dl.Dealer_ID\n",
    "JOIN dim_date        d  ON f.Date_ID   = d.Date_ID\n",
    "GROUP BY f.Dealer_ID, dl.DealerName, d.Year, d.Quarter\n",
    "ORDER BY d.Year, d.Quarter, Total_Revenue DESC;\n",
    "\n",
    "-- ------------------------------------------------------------\n",
    "-- VIEW 4: Monthly Trend\n",
    "-- ------------------------------------------------------------\n",
    "CREATE OR REPLACE VIEW vw_monthly_trend AS\n",
    "SELECT\n",
    "    d.Year,\n",
    "    d.Quarter,\n",
    "    d.Month,\n",
    "    DATE_FORMAT(\n",
    "        TO_DATE(CONCAT(d.Year,'-',LPAD(d.Month,2,'0'),'-01')),\n",
    "        'MMM-yyyy'\n",
    "    )                           AS Month_Label,\n",
    "    ROUND(SUM(f.Revenue),    2) AS Total_Revenue,\n",
    "    SUM(f.Units_Sold)           AS Total_Units,\n",
    "    ROUND(AVG(f.Revenue),    2) AS Avg_Revenue\n",
    "FROM fact_sales  f\n",
    "JOIN dim_date    d ON f.Date_ID = d.Date_ID\n",
    "GROUP BY d.Year, d.Quarter, d.Month\n",
    "ORDER BY d.Year, d.Month;"
   ]
  }

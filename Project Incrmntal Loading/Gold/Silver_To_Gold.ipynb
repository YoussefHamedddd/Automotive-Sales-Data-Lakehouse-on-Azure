   "source": [
    "# silver to gold\n",
    "from delta.tables import DeltaTable\n",
    "\n",
    "storage_account = \"youssef1235445\"\n",
    "container_gold  = \"gold\"\n",
    "gold_path       = f\"abfss://{container_gold}@{storage_account}.dfs.core.windows.net/gold_layer\"\n",
    "CATALOG         = \"cars_catalog\"\n",
    "SCHEMA          = \"gold\"\n",
    "\n",
    "tables = [\n",
    "    \"dim_date\",\n",
    "    \"dim_branch\", \n",
    "    \"dim_dealer\",\n",
    "    \"dim_product\",\n",
    "    \"fact_sales\"\n",
    "]\n",
    "\n",
    "for table in tables:\n",
    "    ,
    "    spark.sql(f\"DROP TABLE IF EXISTS {CATALOG}.{SCHEMA}.{table}\")\n",
    "    print(f\" Dropped table: {CATALOG}.{SCHEMA}.{table}\")\n",
    "    \n",
    "    ,
    "    dbutils.fs.rm(f\"{gold_path}/{table}\", recurse=True)\n",
    "    print(f\" Dropped files: {gold_path}/{table}\")"
   ]
  },

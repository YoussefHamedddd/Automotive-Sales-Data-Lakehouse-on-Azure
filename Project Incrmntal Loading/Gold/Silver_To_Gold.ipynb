   "source": [
    "from pyspark.sql import functions as F\n",
    "from delta.tables import DeltaTable\n",
    "\n",
    "# ============================================================\n",
    "# CONFIG\n",
    "# ============================================================\n",
    "storage_account  = \"youssef1235445\"\n",
    "container_silver = \"silver\"\n",
    "container_gold   = \"gold\"\n",
    "\n",
    "silver_path = f\"abfss://{container_silver}@{storage_account}.dfs.core.windows.net/sales_data_silver\"\n",
    "gold_path   = f\"abfss://{container_gold}@{storage_account}.dfs.core.windows.net/gold_layer\"\n",
    "\n",
    "CATALOG = \"cars_catalog\"\n",
    "SCHEMA  = \"gold\"\n",
    "\n",
    "spark.sql(f\"CREATE CATALOG IF NOT EXISTS {CATALOG}\")\n",
    "spark.sql(f\"CREATE SCHEMA  IF NOT EXISTS {CATALOG}.{SCHEMA}\")\n",
    "\n",
    "# ============================================================\n",
    "# READ SILVER\n",
    "# ============================================================\n",
    "df_silver = spark.read.format(\"delta\").load(silver_path)\n",
    "print(f\" Silver rows loaded: {df_silver.count()}\")\n",
    "\n",
    "# ============================================================\n",
    "# HELPER\n",
    "# ============================================================\n",
    "def save_gold(df, table_name, merge_key):\n",
    "    full_path       = f\"{gold_path}/{table_name}\"\n",
    "    full_table_name = f\"{CATALOG}.{SCHEMA}.{table_name}\"\n",
    "\n",
    "    if DeltaTable.isDeltaTable(spark, full_path):\n",
    "        DeltaTable.forPath(spark, full_path).alias(\"target\").merge(\n",
    "            df.alias(\"source\"),\n",
    "            f\"target.{merge_key} = source.{merge_key}\"\n",
    "        ).whenMatchedUpdateAll().whenNotMatchedInsertAll().execute()\n",
    "        print(f\" MERGED  → {full_table_name}\")\n",
    "    else:\n",
    "        df.write.format(\"delta\").mode(\"overwrite\").save(full_path)\n",
    "        print(f\" CREATED → {full_table_name}\")\n",
    "\n",
    "    spark.sql(f\"\"\"\n",
    "        CREATE TABLE IF NOT EXISTS {full_table_name}\n",
    "        USING DELTA LOCATION '{full_path}'\n",
    "    \"\"\")\n",
    "\n",
    "# ============================================================\n",
    "# DIM TABLES\n",
    "# ============================================================\n",
    "dim_date = (\n",
    "    df_silver\n",
    "    .select(\"Date_ID\", \"Day\", \"Month\", \"Year\")\n",
    "    .dropDuplicates([\"Date_ID\"])\n",
    "    .withColumn(\"Quarter\",\n",
    "        F.when(F.col(\"Month\").between(1, 3), 1)\n",
    "         .when(F.col(\"Month\").between(4, 6), 2)\n",
    "         .when(F.col(\"Month\").between(7, 9), 3)\n",
    "         .otherwise(4))\n",
    "    .withColumn(\"Season\",\n",
    "        F.when(F.col(\"Month\").between(3, 5),  F.lit(\"Spring\"))\n",
    "         .when(F.col(\"Month\").between(6, 8),  F.lit(\"Summer\"))\n",
    "         .when(F.col(\"Month\").between(9, 11), F.lit(\"Autumn\"))\n",
    "         .otherwise(F.lit(\"Winter\")))\n",
    "    .withColumn(\"Full_Date\",\n",
    "        F.to_date(F.concat_ws(\"-\",\n",
    "            F.col(\"Year\"),\n",
    "            F.lpad(F.col(\"Month\"), 2, \"0\"),\n",
    "            F.lpad(F.col(\"Day\"),   2, \"0\")\n",
    "        ), \"yyyy-MM-dd\"))\n",
    ")\n",
    "save_gold(dim_date, \"dim_date\", \"Date_ID\")\n",
    "\n",
    "dim_branch = (\n",
    "    df_silver.select(\"Branch_ID\", \"BranchName\")\n",
    "    .dropDuplicates([\"Branch_ID\"])\n",
    "    .withColumn(\"BranchName\", F.initcap(F.trim(F.col(\"BranchName\"))))\n",
    ")\n",
    "save_gold(dim_branch, \"dim_branch\", \"Branch_ID\")\n",
    "\n",
    "dim_dealer = (\n",
    "    df_silver.select(\"Dealer_ID\", \"DealerName\")\n",
    "    .dropDuplicates([\"Dealer_ID\"])\n",
    "    .withColumn(\"DealerName\", F.initcap(F.trim(F.col(\"DealerName\"))))\n",
    ")\n",
    "save_gold(dim_dealer, \"dim_dealer\", \"Dealer_ID\")\n",
    "\n",
    "dim_product = (\n",
    "    df_silver.select(\"Model_ID\", \"Product_Name\")\n",
    "    .dropDuplicates([\"Model_ID\"])\n",
    "    .withColumn(\"Product_Name\", F.initcap(F.trim(F.col(\"Product_Name\"))))\n",
    "    .withColumn(\"Brand\", F.split(F.col(\"Product_Name\"), \" \")[0])\n",
    ")\n",
    "save_gold(dim_product, \"dim_product\", \"Model_ID\")\n",
    "\n",
    "# ============================================================\n",
    "# FACT TABLE\n",
    "# ============================================================\n",
    "fact_sales = (\n",
    "    df_silver\n",
    "    .select(\"Date_ID\", \"Branch_ID\", \"Dealer_ID\",\n",
    "            \"Model_ID\", \"Revenue\", \"Units_Sold\")\n",
    "    .withColumn(\"Sale_SK\",\n",
    "        F.sha2(F.concat_ws(\"_\",\n",
    "            F.col(\"Date_ID\"),   F.col(\"Branch_ID\"),\n",
    "            F.col(\"Dealer_ID\"), F.col(\"Model_ID\")\n",
    "        ), 256))\n",
    ")\n",
    "save_gold(fact_sales, \"fact_sales\", \"Sale_SK\")\n",
    "\n",
    "print(\"\\n Gold Core Tables Done!\")\n",
    "spark.sql(f\"SHOW TABLES IN {CATALOG}.{SCHEMA}\").show()"
   ]
  },
